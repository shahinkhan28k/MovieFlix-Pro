rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper functions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isEmailVerified() { 
      return isSignedIn() && request.auth.token.email_verified == true; 
    }
    
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == "djskshahin544@gmail.com" || 
        request.auth.token.email == "admin@movieflix.com" || 
        request.auth.token.email == "shahinkhan28qqqq@gmail.com"
      ); 
    }

    // Movies Collection Security
    match /movies/{movieId} {
      // Public read access is required so standard visitors can load the catalog on mount
      allow read: if true;
      
      // Writes are restricted exclusively to verified admin
      allow create: if isAdmin() && isValidMovie(request.resource.data);
      allow update: if isAdmin() && isValidMovie(request.resource.data);
      allow delete: if isAdmin();
    }

    // Settings Collection Security (AdSense & App Configuration)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users Collection Security
    match /users/{userId} {
      // Owner or Admin read and write access
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Movie validation schema helper
    function isValidMovie(data) {
      return data.keys().hasAll(['id', 'title', 'description', 'thumbnail', 'videoUrl', 'category', 'year', 'duration', 'rating', 'featured', 'views', 'likes', 'createdAt'])
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.description is string && data.description.size() <= 5000
        && data.thumbnail is string && data.thumbnail.size() <= 2048
        && data.videoUrl is string && data.videoUrl.size() <= 2048
        && data.category is string && data.category.size() <= 50
        && data.year is int
        && data.duration is string && data.duration.size() <= 20
        && data.rating is string && data.rating.size() <= 10
        && data.featured is bool
        && data.views is int
        && data.likes is int
        && data.createdAt is string;
    }

    // User document validation helper (allows flexible user profile and permissions)
    function isValidUser(data) {
      return data.favorites is list
        && data.watchHistory is list;
    }
  }
}
